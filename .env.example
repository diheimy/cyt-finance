# ─────────────────────────────────────────────────────────────
# CYT Finance — portas reservadas para dev local
# (escolhidas para evitar conflito com outros projetos Docker)
#
#   Web (Vite dev)   : 5173
#   Web (preview)    : 4173
#   API (FastAPI)    : 8020     ← 8000 ocupada pelo portainer
#   Supabase Kong    : 54341    ← 54321 ocupada por dom-finan
#   Supabase DB      : 54342
#   Supabase Studio  : 54343
#   Supabase Inbucket: 54344
# ─────────────────────────────────────────────────────────────

# Frontend (VITE_ prefix = exposto ao browser)
VITE_SUPABASE_URL=http://localhost:54341
VITE_SUPABASE_ANON_KEY=eyJ...
VITE_API_URL=http://localhost:8020

# Backend FastAPI (NUNCA commitar — use .env local + secrets em prod)
SUPABASE_URL=http://localhost:54341
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=super-secret-jwt-signing-key
CRON_SECRET=change-me-in-prod
RESEND_API_KEY=re_...
APP_URL=http://localhost:5173

# Supabase CLI local (gerado por `supabase start`)
# SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54342/postgres

# Em produção, sobrescrever:
#   VITE_SUPABASE_URL=https://<projeto>.supabase.co
#   VITE_API_URL=https://cyt-finance-api.fly.dev
#   SUPABASE_URL=https://<projeto>.supabase.co
