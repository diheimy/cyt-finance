{
  "name": "cyt-finance",
  "version": "0.1.0",
  "private": true,
  "description": "CYT Finance v2 — gestão financeira pessoal e familiar (Supabase + FastAPI + React)",
  "scripts": {
    "dev:web": "pnpm --filter @cyt/web dev",
    "build:web": "pnpm --filter @cyt/web build",
    "lint:web": "pnpm --filter @cyt/web lint",
    "typecheck:web": "pnpm --filter @cyt/web typecheck",
    "test:web": "pnpm --filter @cyt/web test -- --run",
    "gen:types": "supabase gen types typescript --local > apps/web/src/types/database.ts",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
